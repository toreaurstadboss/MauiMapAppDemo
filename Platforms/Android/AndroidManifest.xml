<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.toreaurstadid.mauiappdemo" android:versionCode="1">
	<application android:allowBackup="true" android:icon="@mipmap/appicon"
				 android:supportsRtl="true" android:label="Maui Map App Demo">

		<!-- Replace with your own Google Maps API key -->
		<!-- Use the placeholder variable here -->
		<meta-data android:name="com.google.android.geo.API_KEY" android:value="${GoogleMapsApiKey}" />


	</application>
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="android.permission.INTERNET" />
	
	
</manifest>