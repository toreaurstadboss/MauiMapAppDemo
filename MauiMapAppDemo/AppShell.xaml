<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiMapAppDemo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiMapAppDemo"
    xmlns:pages="clr-namespace:MauiMapAppDemo.Pages"
    Title="MauiMapAppDemo"
    FlyoutBehavior="Flyout">

    <MenuItem
        Text="📏 Toggle measure mode"
        Command="{Binding ToggleMeasureModeCommand}" />   
    

    <MenuItem
     Text="⛰️ Toggle height profile mode"
     Command="{Binding ToggleHeightProfileCommand}" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate pages:MapsDemo}"
        Route="MapsPage" />

</Shell>
